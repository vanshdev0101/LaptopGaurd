<Window x:Class="LaptopGuard.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Laptop Guard — Security Monitor"
        Height="780" Width="1280"
        MinHeight="680" MinWidth="1080"
        WindowStartupLocation="CenterScreen"
        Background="#0f1923">

	<Window.Resources>
		<Style x:Key="StatCard" TargetType="Border">
			<Setter Property="Background"      Value="#162032"/>
			<Setter Property="CornerRadius"    Value="4"/>
			<Setter Property="BorderBrush"     Value="#1e4976"/>
			<Setter Property="BorderThickness" Value="0,0,0,3"/>
		</Style>

		<Style x:Key="PanelCard" TargetType="Border">
			<Setter Property="Background"      Value="#111c2a"/>
			<Setter Property="CornerRadius"    Value="4"/>
			<Setter Property="BorderBrush"     Value="#1e3a5f"/>
			<Setter Property="BorderThickness" Value="1"/>
		</Style>

		<Style x:Key="PanelHeader" TargetType="Border">
			<Setter Property="Background"      Value="#0d1520"/>
			<Setter Property="BorderBrush"     Value="#1e3a5f"/>
			<Setter Property="BorderThickness" Value="0,0,0,1"/>
			<Setter Property="Padding"         Value="14,0"/>
		</Style>

		<Style x:Key="SentinelBtn" TargetType="Button">
			<Setter Property="Background"      Value="#162032"/>
			<Setter Property="BorderBrush"     Value="#1e4976"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding"         Value="16,8"/>
			<Setter Property="FontWeight"      Value="SemiBold"/>
			<Setter Property="FontSize"        Value="11"/>
			<Setter Property="FontFamily"      Value="Segoe UI"/>
			<Setter Property="Cursor"          Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
							<ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</Window.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="48"/>
			<RowDefinition Height="8"/>
			<RowDefinition Height="110"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="48"/>
		</Grid.RowDefinitions>

		<!-- ── Top Bar ── -->
		<Border Grid.Row="0" Background="#0a1220"
                BorderBrush="#1e3a5f" BorderThickness="0,0,0,1">
			<Grid Margin="16,0">
				<!-- Left: Brand -->
				<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
					<Rectangle Width="3" Height="22" Fill="#2563eb"
                               RadiusX="1" RadiusY="1" Margin="0,0,10,0"/>
					<TextBlock Text="LAPTOP GUARD"
                               FontSize="14" FontWeight="Bold"
                               FontFamily="Segoe UI"
                               Foreground="#e2e8f0"
                               VerticalAlignment="Center"/>
					<TextBlock Text="  |  SECURITY MONITOR"
                               FontSize="11" Foreground="#2563eb"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"/>
				</StackPanel>

				<!-- Right: Status pill -->
				<StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
					<Border Background="#0a1f3a" CornerRadius="2"
                            BorderBrush="#1e4976" BorderThickness="1"
                            Padding="10,4" Margin="0,0,8,0">
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="MONITOR  "
                                       FontSize="9" Foreground="#4a7ab5"
                                       FontFamily="Segoe UI" FontWeight="SemiBold"/>
							<TextBlock x:Name="ServiceStatusText"
                                       Text="● CHECKING"
                                       FontSize="9" FontWeight="Bold"
                                       FontFamily="Segoe UI"
                                       Foreground="#f59e0b"/>
						</StackPanel>
					</Border>
				</StackPanel>
			</Grid>
		</Border>

		<!-- ── Blue accent line ── -->
		<Rectangle Grid.Row="1" Height="2" VerticalAlignment="Top"
                   Fill="#2563eb" Opacity="0.6"/>

		<!-- ── Stat Cards ── -->
		<Grid Grid.Row="2" Margin="14,10,14,6">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="1.8*"/>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<!-- Total -->
			<Border Grid.Column="0" Style="{StaticResource StatCard}"
                    Margin="0,0,6,0" BorderBrush="#c0392b">
				<StackPanel Margin="16,14">
					<TextBlock Text="TOTAL ATTEMPTS"
                               FontSize="8" Foreground="#4a7ab5"
                               FontFamily="Segoe UI" FontWeight="SemiBold"/>
					<TextBlock x:Name="TotalText" Text="—"
                               FontSize="36" FontWeight="Bold"
                               Foreground="#e74c3c" FontFamily="Segoe UI"/>
					<TextBlock Text="all time"
                               FontSize="8" Foreground="#2a3f5a"
                               FontFamily="Segoe UI"/>
				</StackPanel>
			</Border>

			<!-- Today -->
			<Border Grid.Column="1" Style="{StaticResource StatCard}"
                    Margin="0,0,6,0" BorderBrush="#e67e22">
				<StackPanel Margin="16,14">
					<TextBlock Text="TODAY"
                               FontSize="8" Foreground="#4a7ab5"
                               FontFamily="Segoe UI" FontWeight="SemiBold"/>
					<TextBlock x:Name="TodayText" Text="—"
                               FontSize="36" FontWeight="Bold"
                               Foreground="#e67e22" FontFamily="Segoe UI"/>
					<TextBlock Text="incidents"
                               FontSize="8" Foreground="#2a3f5a"
                               FontFamily="Segoe UI"/>
				</StackPanel>
			</Border>

			<!-- OTP -->
			<Border Grid.Column="2" Style="{StaticResource StatCard}"
                    Margin="0,0,6,0" BorderBrush="#2563eb">
				<Grid Margin="16,10">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>
					<StackPanel Grid.Column="0" VerticalAlignment="Center">
						<TextBlock Text="LIVE OTP TOKEN"
                                   FontSize="8" Foreground="#4a7ab5"
                                   FontFamily="Segoe UI" FontWeight="SemiBold"/>
						<TextBlock x:Name="OtpText" Text="------"
                                   FontSize="40" FontWeight="Bold"
                                   Foreground="#3b82f6" FontFamily="Consolas"/>
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="Expires in "
                                       FontSize="8" Foreground="#2a3f5a"
                                       FontFamily="Segoe UI"/>
							<TextBlock x:Name="OtpTimerText" Text="30s"
                                       FontSize="8" Foreground="#3b82f6"
                                       FontFamily="Segoe UI" FontWeight="Bold"/>
						</StackPanel>
					</StackPanel>
					<!-- Timer bar -->
					<Border Grid.Column="1" Width="6" Background="#0a1220"
                            CornerRadius="3" Margin="10,4,0,4">
						<Border x:Name="OtpBar" Background="#2563eb"
                                CornerRadius="3" VerticalAlignment="Bottom"
                                Height="80"/>
					</Border>
				</Grid>
			</Border>

			<!-- Last Seen -->
			<Border Grid.Column="3" Style="{StaticResource StatCard}"
                    Margin="0,0,6,0" BorderBrush="#1e4976">
				<StackPanel Margin="16,14">
					<TextBlock Text="LAST SEEN"
                               FontSize="8" Foreground="#4a7ab5"
                               FontFamily="Segoe UI" FontWeight="SemiBold"/>
					<TextBlock x:Name="LastSeenText" Text="—"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#7fb3e8" FontFamily="Consolas"/>
					<TextBlock Text="timestamp"
                               FontSize="8" Foreground="#2a3f5a"
                               FontFamily="Segoe UI"/>
				</StackPanel>
			</Border>

			<!-- Photos -->
			<Border Grid.Column="4" Style="{StaticResource StatCard}"
                    BorderBrush="#1e4976">
				<StackPanel Margin="16,14">
					<TextBlock Text="EVIDENCE FILES"
                               FontSize="8" Foreground="#4a7ab5"
                               FontFamily="Segoe UI" FontWeight="SemiBold"/>
					<TextBlock x:Name="PhotosText" Text="—"
                               FontSize="36" FontWeight="Bold"
                               Foreground="#7fb3e8" FontFamily="Segoe UI"/>
					<TextBlock Text="photos saved"
                               FontSize="8" Foreground="#2a3f5a"
                               FontFamily="Segoe UI"/>
				</StackPanel>
			</Border>
		</Grid>

		<!-- ── Body ── -->
		<Grid Grid.Row="3" Margin="14,0,14,6">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="380"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<!-- Left: Photo Grid -->
			<Border Grid.Column="0" Style="{StaticResource PanelCard}"
                    Margin="0,0,6,0">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="44"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>
					<Border Grid.Row="0" Style="{StaticResource PanelHeader}"
                            CornerRadius="4,4,0,0">
						<Grid>
							<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
								<Rectangle Width="2" Height="14" Fill="#2563eb"
                                           Margin="0,0,8,0"/>
								<TextBlock Text="EVIDENCE GALLERY"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="#7fb3e8" FontFamily="Segoe UI"/>
							</StackPanel>
							<Button x:Name="RefreshBtn" Content="REFRESH"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Click="RefreshBtn_Click"
                                    Style="{StaticResource SentinelBtn}"
                                    Foreground="#4a7ab5"
                                    Padding="8,3" FontSize="9"/>
						</Grid>
					</Border>
					<ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="Transparent">
						<WrapPanel x:Name="PhotoGrid" Margin="8"
                                   Orientation="Horizontal"/>
					</ScrollViewer>
				</Grid>
			</Border>

			<!-- Right -->
			<Grid Grid.Column="1">
				<Grid.RowDefinitions>
					<RowDefinition Height="*"/>
					<RowDefinition Height="220"/>
				</Grid.RowDefinitions>

				<!-- Preview -->
				<Border Grid.Row="0" Style="{StaticResource PanelCard}"
                        Margin="0,0,0,6">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="44"/>
							<RowDefinition Height="*"/>
						</Grid.RowDefinitions>
						<Border Grid.Row="0" Style="{StaticResource PanelHeader}"
                                CornerRadius="4,4,0,0">
							<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
								<Rectangle Width="2" Height="14" Fill="#2563eb"
                                           Margin="0,0,8,0"/>
								<TextBlock Text="INCIDENT PREVIEW"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="#7fb3e8" FontFamily="Segoe UI"/>
							</StackPanel>
						</Border>
						<Grid Grid.Row="1" Background="#0a1220">
							<Image x:Name="PreviewImage" Margin="12"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
							<StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        x:Name="PreviewPlaceholder">
								<TextBlock Text="NO INCIDENT SELECTED"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="#1e3a5f"
                                           FontFamily="Segoe UI"
                                           HorizontalAlignment="Center"/>
								<TextBlock Text="← Select evidence from the gallery"
                                           FontSize="10" Foreground="#162032"
                                           FontFamily="Segoe UI"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,0"/>
							</StackPanel>
						</Grid>
					</Grid>
				</Border>

				<!-- Log -->
				<Border Grid.Row="1" Style="{StaticResource PanelCard}">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="44"/>
							<RowDefinition Height="*"/>
						</Grid.RowDefinitions>
						<Border Grid.Row="0" Style="{StaticResource PanelHeader}"
                                CornerRadius="4,4,0,0">
							<Grid>
								<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
									<Rectangle Width="2" Height="14" Fill="#2563eb"
                                               Margin="0,0,8,0"/>
									<TextBlock Text="INCIDENT LOG"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="#7fb3e8" FontFamily="Segoe UI"/>
								</StackPanel>
								<StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center">
									<Ellipse Width="6" Height="6" Fill="#10b981"
                                             Margin="0,0,4,0"/>
									<TextBlock x:Name="LiveDot" Text="LIVE"
                                               FontSize="8" FontWeight="Bold"
                                               Foreground="#10b981"
                                               FontFamily="Segoe UI"/>
								</StackPanel>
							</Grid>
						</Border>
						<RichTextBox x:Name="LogBox" Grid.Row="1"
                                     Margin="8,4,8,8"
                                     Background="#080f1a"
                                     Foreground="#4a7ab5"
                                     FontFamily="Consolas" FontSize="10"
                                     IsReadOnly="True" BorderThickness="0"
                                     VerticalScrollBarVisibility="Auto"/>
					</Grid>
				</Border>
			</Grid>
		</Grid>

		<!-- ── Footer ── -->
		<Border Grid.Row="4" Background="#0a1220"
                BorderBrush="#1e3a5f" BorderThickness="0,1,0,0">
			<Grid Margin="14,0">
				<StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
					<Button Content="📁  OPEN EVIDENCE FOLDER"
                            Click="OpenFolderBtn_Click"
                            Style="{StaticResource SentinelBtn}"
                            Foreground="#4a7ab5"/>
				</StackPanel>
				<StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
					<Button Content="⏹  STOP MONITOR"
                            Click="StopServiceBtn_Click"
                            Style="{StaticResource SentinelBtn}"
                            Foreground="#e74c3c" Margin="0,0,8,0"/>
					<Button Content="▶  START MONITOR"
                            Click="StartServiceBtn_Click"
                            Style="{StaticResource SentinelBtn}"
                            Foreground="#10b981"/>
				</StackPanel>
			</Grid>
		</Border>
	</Grid>
</Window>
